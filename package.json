{
  "name": "heal-vcf-upload",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "api": "node server/dev-api.js",
    "api:prod": "node server/dev-api.js",
    "start": "concurrently \"npm run api\" \"npm run dev\"",
